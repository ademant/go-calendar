#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if systemctl is-active --quiet dansal-web.service 2>/dev/null; then
            systemctl stop dansal-web.service || true
        fi
        if systemctl is-active --quiet dansal.service 2>/dev/null; then
            systemctl stop dansal.service || true
        fi
        ;;
esac
